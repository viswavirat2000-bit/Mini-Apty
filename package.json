{
  "name": "mini-apty-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "Mini_Apty/*"
  ],
  "scripts": {
    "typecheck:extension": "cd Mini_Apty/extension && npm run tsc -- --noEmit",
    "typecheck:backend": "cd Mini_Apty/backend && npm run tsc -- --noEmit",
    "typecheck": "npm run typecheck:extension && npm run typecheck:backend",
    "build:extension": "cd Mini_Apty/extension && npm run build",
    "build:backend": "cd Mini_Apty/backend && npm run build",
    "build": "npm run build:extension && npm run build:backend",
    "ci": "npm run typecheck && npm run build",
    "dev:backend": "cd Mini_Apty/backend && npm run dev",
    "lint": "echo \"Add lint scripts per-package\""
  }
}
